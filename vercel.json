{
  "version": 2,
  "outputDirectory": ".",
  "cleanUrls": true,
  "functions": {
    "api/auth.js": { "maxDuration": 10 },
    "api/razorpay-config.js": { "maxDuration": 5 },
    "api/payments/create-order.js": { "maxDuration": 10 },
    "api/payments/verify.js": { "maxDuration": 10 },
    "api/webhooks/razorpay.js": { "maxDuration": 10 },
    "api/logs.js": { "maxDuration": 5 }
  },
  "rewrites": [
    { "source": "/api/auth/:action*", "destination": "/api/auth" },
    { "source": "/passport", "destination": "/passport/index.html" },
    { "source": "/dashboard", "destination": "/dashboard/index.html" },
    { "source": "/ecosystem", "destination": "/ecosystem/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.(?:js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|webp|gif|ico|avif))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" },
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization, x-country-code" }
      ]
    }
  ]
}
